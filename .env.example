# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Late API key and AI Gateway key are set per-workspace in Settings UI.
# For self-hosted, you can optionally set AI_GATEWAY_API_KEY as a fallback.

# AI Gateway (for AI Response flow node, optional for self-hosted)
# On Vercel: configure provider keys in AI Gateway settings (automatic OIDC auth)
# Self-hosted: set this key from https://vercel.com/ai-gateway
# AI_GATEWAY_API_KEY=your-gateway-key

# Cron secret (for sequence processor + job scheduler)
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Fork-only: Docker dev stack ──────────────────────────────────────────────
# ngrok authtoken (從 https://dashboard.ngrok.com/get-started/your-authtoken 拿)
# 給 docker/docker-compose.yml 的 ngrok service 用
NGROK_AUTHTOKEN=your-ngrok-authtoken
